# SakuraNavi Backend — Environment Variables Example
# 將本檔複製為 .env.development 或 .env.production 後填入真實值。
# 啟動應用程式前請確保 APP_ENV 環境變數與目標環境一致。
#
# 產生指令參考：
#   SECRET_KEY / PHONE_HMAC_KEY  → python -c "import secrets; print(secrets.token_hex(32))"
#   PHONE_ENCRYPTION_KEY          → python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"

# ── App ───────────────────────────────────────────────────────────────────────
# development | production
APP_ENV=development
DEBUG=false
PORT=8000

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+psycopg://<user>:<password>@localhost:5432/<database>

# ── Auth ──────────────────────────────────────────────────────────────────────
# 最少 32 字元的隨機字串；建議使用 secrets.token_hex(32) 產生
SECRET_KEY=your_64_char_hex_secret_key_here

# Access Token 效期（分鐘）
ACCESS_TOKEN_EXPIRE_MINUTES=15

# Refresh Token 效期（天）
REFRESH_TOKEN_EXPIRE_DAYS=7

# bcrypt cost factor（開發可用 10，正式建議 12）
BCRYPT_ROUNDS=12

# ── Phone Encryption ──────────────────────────────────────────────────────────
# Fernet key：URL-safe base64-encoded 32 bytes（44 字元，結尾 =）
# 警告：設定後不可更換，否則既有電話資料無法還原
PHONE_ENCRYPTION_KEY=your_fernet_key_here=

# HMAC 查詢 key：64 字元 hex（32 bytes）
# 警告：設定後不可更換，否則 phone_hmac 索引全部失效
PHONE_HMAC_KEY=your_64_char_hex_hmac_key_here

# ── CORS ──────────────────────────────────────────────────────────────────────
# 逗號分隔的允許 Origin 清單
# 開發範例：http://localhost:3000,http://localhost:5173
# 正式範例：https://sakuranavi.example.com
CORS_ORIGINS=http://localhost:3000
CORS_ALLOW_CREDENTIALS=true

# ── MiniMax LLM ──────────────────────────────────────────────────────────────
# MiniMax API Key
MINIMAX_API_KEY=your_minimax_api_key_here

# MiniMax API Base URL (OpenAI-compatible)
MINIMAX_BASE_URL=https://api.minimax.io/v1

# MiniMax Model Name
MINIMAX_MODEL=MiniMax-M2.7

# Max tokens per response
MINIMAX_MAX_TOKENS=4096

# Sampling temperature (0.0–2.0, lower = more deterministic)
MINIMAX_TEMPERATURE=0.7

# ── Gemini LLM ───────────────────────────────────────────────────────────────
# Gemini API Key
GEMINI_API_KEY=your_gemini_api_key_here

# Gemini API Base URL (OpenAI-compatible endpoint)
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/

# Gemini Model Name
GEMINI_MODEL=gemini-3-flash-preview